{
  "name": "quantsieve",
  "version": "1.0.0",
  "description": "AI-powered stock & mutual fund evaluator for Indian retail investors",
  "type": "module",
  "bin": {
    "quantsieve": "./dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "dev:server": "tsx src/server.ts",
    "dev:frontend": "cd frontend && npm run dev",
    "build": "tsup src/index.ts src/server.ts --format esm --dts",
    "build:frontend": "cd frontend && npm run build",
    "build:all": "npm run build && npm run build:frontend",
    "start": "node dist/server.js",
    "setup:frontend": "cd frontend && npm install"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.39.0",
    "chalk": "^5.4.1",
    "cheerio": "^1.0.0",
    "commander": "^13.1.0",
    "dotenv": "^16.4.7",
    "express": "^5.2.1",
    "inquirer": "^12.5.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@types/express": "^5.0.6",
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^5.8.2"
  }
}
